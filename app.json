{
  "expo": {
    "name": "NatureFind",
    "slug": "park-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "naturefind",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1b4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.finn581.parkfinder",
      "buildNumber": "55",
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NatureFind uses your location to show nearby national parks on the map.",
        "NSPhotoLibraryUsageDescription": "NatureFind needs access to your photos to attach them to reviews.",
        "NSPhotoLibraryAddUsageDescription": "NatureFind saves selected photos for your review.",
        "NSCameraUsageDescription": "NatureFind uses your camera to photograph wildlife sightings.",
        "ITSAppUsesNonExemptEncryption": false,
        "MBXAccessToken": "pk.eyJ1IjoiZmlubnk2MTkiLCJhIjoiY21taTYzZHhxMDhpbzJxcTRxMDFuZW82aSJ9._JSEGDLmBGvl-7sB375Kbg",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1063234127083-o4bs0m1dcpsfs05953lpd0k8nn17dlc3"
            ]
          }
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1b1b1b"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.finn581.parkfinder",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withRnmapboxFix",
      "expo-router",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NatureFind uses your location to show nearby national parks."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "NatureFind needs access to your photos to attach them to reviews."
        }
      ],
      "react-native-iap",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db5458c2-c31c-4e46-aea6-ad7df568951b"
      }
    }
  }
}
