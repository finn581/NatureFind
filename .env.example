# National Park Service API key (https://www.nps.gov/subjects/developer/get-started.htm)
EXPO_PUBLIC_NPS_API_KEY=your_nps_api_key

# Geoapify API key (https://www.geoapify.com/)
EXPO_PUBLIC_GEOAPIFY_KEY=your_geoapify_key

# Google OAuth iOS Client ID (from Google Cloud Console > Credentials)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
